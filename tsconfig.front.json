{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Node",
    "outDir": "./public/js",
    "rootDir": "./src/frontend",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "noImplicitAny": false
  },
  "include": ["src/frontend/**/*"]
}