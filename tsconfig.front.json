{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ES2022",
    "moduleResolution": "Node",
    "outDir": "./public/js",
    "rootDir": "./src/frontend",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "noImplicitAny": false
  },
  "include": [
    "src/frontend/**/*"
  ]
}